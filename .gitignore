# Local config (copy from config.example.yaml)
config.yaml

# Docker compose secrets (copy from .env.example)
.env

# License tokens — signed credentials minted by `cmd/license`; never commit.
# `licence.{pharmacy,retail}.example` are local sample tokens for testing
# Settings > License (one per business mode).
licence*.example
*.license

# Local docker volumes (postgres data, etc.)
data/

# Go
/backend/bin/
/backend/tmp/
*.test
*.out

# Local SQLite dev database (database.driver: sqlite) + its WAL/SHM sidecars.
# The file is the developer's local data; never commit it.
/backend/justmart.db
/backend/justmart.db-shm
/backend/justmart.db-wal

# Node / frontend
node_modules/
.vite/
# tsc -b incremental cache — a build artifact; tracking it can mask type errors.
*.tsbuildinfo
# Build outputs: frontend bundle + the compiled single binary.
/frontend/dist/
/dist/

# Embedded SPA: the build copies frontend/dist here before `go build`; keep the
# committed stub so //go:embed compiles, ignore everything the build drops in.
/backend/internal/web/dist/*
!/backend/internal/web/dist/.gitkeep

# Playwright
frontend/tests/e2e/.auth/
frontend/test-results/
frontend/playwright-report/

# Windows installer build artifacts (assembled payload + cached downloads)
packaging/windows/payload/
packaging/windows/.cache/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log


thirdparties/bin
server.exe
license.exe