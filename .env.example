# Copy to .env for `docker compose -f docker-compose.prod.yml`. .env is gitignored.
# Generate a strong secret, e.g.:  openssl rand -hex 32
JUSTMART_JWT_SECRET=change-me-to-a-long-random-string
JUSTMART_DB_PASSWORD=change-me
JUSTMART_OWNER_EMAIL=owner@justmart.local
JUSTMART_OWNER_PASSWORD=change-me-on-first-login
# Shop timezone for the "today" boundary in dashboards.
JUSTMART_TZ=Asia/Jakarta
